{
  "datasets": [
    {
      "name": "c045c11f",
      "displayName": "Accident by City",
      "queryLines": [
        "SELECT city, total_accidents AS accident_count\r\n",
        "FROM traffic_catalog.traffic_schema.hotspots_gold\r\n",
        "ORDER BY accident_count DESC"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "2efb6c55",
      "displayName": "Total Accidents",
      "queryLines": [
        "SELECT COUNT(*) AS total_accidents\r\n",
        "FROM traffic_catalog.traffic_schema.accidents_silver"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "e5c7d573",
      "displayName": "Avg Severity KPI",
      "queryLines": [
        "SELECT ROUND(AVG(severity),2) AS avg_severity\r\n",
        "FROM traffic_catalog.traffic_schema.accidents_silver"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "d7dc787b",
      "displayName": "Top City KPI",
      "queryLines": [
        "SELECT city\r\n",
        "FROM traffic_catalog.traffic_schema.hotspots_gold\r\n",
        "ORDER BY total_accidents DESC\r\n",
        "LIMIT 1"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "1e51db6a",
      "displayName": "Top Violation KPI",
      "queryLines": [
        "SELECT violation_type,total_cases\r\n",
        "FROM traffic_catalog.traffic_schema.violation_summary_gold\r\n",
        "ORDER BY total_cases DESC\r\n",
        "Limit 1\r\n"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "84f399c9",
      "displayName": "Weather Severity",
      "queryLines": [
        "SELECT condition, avg_severity\r\n",
        "FROM traffic_catalog.traffic_schema.weather_impact_gold\r\n",
        "ORDER BY avg_severity DESC"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "2b50d6be",
      "displayName": "Violations",
      "queryLines": [
        "SELECT violation_type, total_cases\r\n",
        "FROM traffic_catalog.traffic_schema.violation_summary_gold\r\n",
        "order by total_cases desc"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "4c1dc828",
      "displayName": "Time Trend",
      "queryLines": [
        "SELECT accident_hour, accident_count     \r\n",
        "FROM traffic_catalog.traffic_schema.accidents_by_hour_gold\r\n",
        "order by accident_hour"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "e7915513",
      "displayName": "Riskiest Road KPI",
      "queryLines": [
        "SELECT road_type\r\n",
        "FROM traffic_catalog.traffic_schema.road_risk_gold\r\n",
        "ORDER BY avg_severity DESC\r\n",
        "LIMIT 1"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "3a41aeb9",
      "displayName": "Accident Trend by Month and Weather",
      "queryLines": [
        "SELECT \r\n",
        "  CASE month(to_date(a.accident_date))\r\n",
        "    WHEN 1 THEN 'Jan'\r\n",
        "    WHEN 2 THEN 'Feb'\r\n",
        "    WHEN 3 THEN 'Mar'\r\n",
        "    WHEN 4 THEN 'Apr'\r\n",
        "    WHEN 5 THEN 'May'\r\n",
        "    WHEN 6 THEN 'Jun'\r\n",
        "    WHEN 7 THEN 'Jul'\r\n",
        "    WHEN 8 THEN 'Aug'\r\n",
        "    WHEN 9 THEN 'Sep'\r\n",
        "    WHEN 10 THEN 'Oct'\r\n",
        "    WHEN 11 THEN 'Nov'\r\n",
        "    WHEN 12 THEN 'Dec'\r\n",
        "  END AS month_name,\r\n",
        "  month(to_date(a.accident_date)) AS month_order,\r\n",
        "  w.condition,\r\n",
        "  COUNT(*) AS accident_count\r\n",
        "FROM traffic_catalog.traffic_schema.accidents_silver a\r\n",
        "JOIN traffic_catalog.traffic_schema.weather_silver w\r\n",
        "  ON a.weather_id = w.weather_id\r\n",
        "GROUP BY month_name, month_order, w.condition\r\n",
        "ORDER BY month_order"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "96147cb7",
      "displayName": "Peak Hour KPI",
      "queryLines": [
        "SELECT \r\n",
        "  CASE \r\n",
        "    WHEN accident_hour = 0 THEN '12 AM'\r\n",
        "    WHEN accident_hour < 12 THEN CONCAT(accident_hour, ' AM')\r\n",
        "    WHEN accident_hour = 12 THEN '12 PM'\r\n",
        "    ELSE CONCAT(accident_hour - 12, ' PM')\r\n",
        "  END AS peak_hour\r\n",
        "FROM traffic_catalog.traffic_schema.accidents_by_hour_gold\r\n",
        "ORDER BY accident_count DESC\r\n",
        "LIMIT 1"
      ],
      "catalog": "traffic_catalog",
      "schema": "traffic_schema"
    },
    {
      "name": "85752d4a",
      "displayName": "City × Road Type Heatmap",
      "queryLines": [
        "SELECT city, road_type, total_accidents as accident_count\r\n",
        "FROM traffic_catalog.traffic_schema.city_roadtype_gold"
      ]
    },
    {
      "name": "5ac7ca14",
      "displayName": "Accidents by City & Road Type",
      "queryLines": [
        "SELECT city, road_type, total_accidents as accident_count\r\n",
        "FROM traffic_catalog.traffic_schema.city_roadtype_gold"
      ]
    },
    {
      "name": "99cfe64c",
      "displayName": "Avg Severity by Weather Condition",
      "queryLines": [
        "SELECT condition, avg_severity\r\n",
        "FROM traffic_catalog.traffic_schema.weather_impact_gold\r\n",
        "ORDER BY avg_severity DESC"
      ]
    },
    {
      "name": "649e69c0",
      "displayName": "Accidents by Hour of Day",
      "queryLines": [
        "SELECT\r\n",
        " CASE \r\n",
        "    WHEN accident_hour = 0 THEN '12 AM'\r\n",
        "    WHEN accident_hour < 12 THEN CONCAT(accident_hour, ' AM')\r\n",
        "    WHEN accident_hour = 12 THEN '12 PM'\r\n",
        "    ELSE CONCAT(accident_hour - 12, ' PM')\r\n",
        "  END AS accident_hour,\r\n",
        "  accident_count,\r\n",
        "  CASE\r\n",
        "    WHEN accident_count >= 8 THEN 'High Risk'\r\n",
        "    WHEN accident_count >= 3 THEN 'Medium Risk'\r\n",
        "    WHEN accident_count <= 2 THEN 'Normal'\r\n",
        "    ELSE 'Calm'\r\n",
        "  END AS hour_risk\r\n",
        "FROM traffic_catalog.traffic_schema.accidents_by_hour_gold\r\n",
        "ORDER BY accident_hour"
      ]
    },
    {
      "name": "f6c10ce6",
      "displayName": "Violation Type Distribution",
      "queryLines": [
        "SELECT violation_type, COUNT(*) AS accident_count\r\n",
        "FROM traffic_catalog.traffic_schema.violations_silver\r\n",
        "WHERE violation_type != 'None'\r\n",
        "GROUP BY violation_type\r\n",
        "ORDER BY accident_count DESC"
      ]
    },
    {
      "name": "a73d89ea",
      "displayName": "Accident by Driver Age Group",
      "queryLines": [
        "SELECT age_group, total_accidents\r\n",
        "FROM traffic_catalog.traffic_schema.age_group_risk_gold\r\n",
        "ORDER BY total_accidents DESC"
      ]
    }
  ],
